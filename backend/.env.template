# --- Core (required) ---
# PostgreSQL connection string (Medusa v2 uses PostgreSQL only in production setups).
# Local example (matches docker-compose in this folder):
#   postgres://medusa:medusa@localhost:5432/medusa
DATABASE_URL=

# Strong random strings — minimum 32 characters (do not reuse across environments).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
COOKIE_SECRET=

# Public browser URL of this Medusa API (Admin uses it to call the backend).
# Local: http://localhost:9000
MEDUSA_BACKEND_URL=http://localhost:9000

# Comma-separated origins (no spaces). Must include your storefront and Admin origins.
# Storefront (Vite default): http://localhost:5173
# Admin is served from the same Medusa server; include http://localhost:9000 for local Admin.
STORE_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:9000
ADMIN_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:9000

# --- Redis (recommended for production; optional in many local flows) ---
# When set, Medusa swaps cache / events / workflow engine to Redis-backed implementations.
REDIS_URL=redis://localhost:6379

# --- Stripe (optional) ---
# Secret key from Stripe Dashboard. When set, the Stripe payment provider is registered (id: stripe → pp_stripe_stripe).
# STRIPE_API_KEY=
# Webhook signing secret (recommended in production for Stripe webhooks).
# STRIPE_WEBHOOK_SECRET=
# Capture automatically after authorization. Set false for manual capture.
STRIPE_CAPTURE=true

# --- PayPal ---
# REST API application credentials from developer.paypal.com.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
# Optional, but required for verified PayPal webhook processing.
# PAYPAL_WEBHOOK_ID=

# Firebase Admin credentials are required when deploying a server-side
# Firebase token bridge. Never expose these as VITE_* variables.
FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- PostgreSQL SSL (optional, typical for managed DBs) ---
# DATABASE_SSL=true
# Set to false only if your provider requires insecure TLS (not recommended).
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# --- Tooling only ---
# MEDUSA_SKIP_ENV_CHECK=true
