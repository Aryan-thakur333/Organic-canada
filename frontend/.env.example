# --- Medusa (required for catalog, cart, checkout) ---
# Publishable Store API key from Medusa Admin (safe in the browser).
VITE_MEDUSA_PUBLISHABLE_KEY=

# Optional: absolute Medusa API URL for production builds, e.g. https://api.example.com
# Leave unset in local dev to use the Vite dev server proxy (/store -> http://localhost:9000).
# VITE_MEDUSA_BACKEND_URL=

# Optional: force a region id when multiple regions exist (otherwise the first region is used).
# VITE_MEDUSA_REGION_ID=

# Optional: public URL for resolving /static/... product images when the API host differs from the storefront.
# VITE_MEDUSA_PUBLIC_URL=http://localhost:9000

# Optional: default ISO country for parsed guest checkout addresses (default dk).
# VITE_STORE_DEFAULT_COUNTRY_CODE=dk

# --- Stripe (card payments) ---
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Firebase Authentication (public browser configuration) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# --- Legacy checkout API (optional; payment-server demo) ---
# VITE_CHECKOUT_API_BASE=

# --- Dev only ---
# VITE_ADMIN_API_KEY=

# Optional: NEVER ship real admin tokens in a public storefront build.
# VITE_MEDUSA_ADMIN_TOKEN=
